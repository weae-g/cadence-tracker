# Скопируйте в .env и задайте свои значения (.env не коммитится).

# Секрет подписи сессий. ОБЯЗАТЕЛЕН в продакшене.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Порт сервера авторизации
PORT=3001

# Время жизни сессии в секундах (по умолчанию 8 часов)
SESSION_TTL_SECONDS=28800

# Режим: в продакшене ставьте production (требует SESSION_SECRET)
NODE_ENV=development

# Secure-cookie: cookie уходит только по HTTPS.
# Если HTTPS НЕТ (деплой по http://) — поставьте false, иначе вход не заработает.
# По умолчанию (если не задано): true в production, false в development.
COOKIE_SECURE=false
