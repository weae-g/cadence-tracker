# Зависимости (ставятся через npm ci на каждой машине — в git их быть не должно;
# собранные под Windows бинарники не работают на сервере Linux).
node_modules/

# Сборка фронтенда (пересоздаётся `npm run build`).
dist/

# Логи и кэш
*.log
npm-debug.log*
.vite/

# Локальные/временные и тестовые артефакты
_test.zip
_ziptest.mjs
_zx/
*.tmp

# Системные файлы ОС
.DS_Store
Thumbs.db

# Редакторы
.idea/
*.swp

# Переменные окружения (если появятся в корне; у сервера свой .env в server/)
.env
.env.local
